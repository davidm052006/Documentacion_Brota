# ==========================================
# VARIABLES DE ENTORNO - FRONTEND
# ==========================================
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env.local
#    cp .env.local.example .env.local
# 2. Rellena cada variable con tus valores reales
# 3. NUNCA subas el archivo .env.local a Git
#
# ¿Dónde consigo estos valores?
# → Supabase: https://supabase.com → Tu Proyecto → Settings → API
# ==========================================

# URL de tu proyecto (Settings → API → Project URL)
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Anon Key - Esta sí puede estar en el frontend (es pública)
# (Settings → API → Project API Keys → anon → Reveal)
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
