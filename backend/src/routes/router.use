// Helper para manejar errores de Supabase
async function handleSupabase(res, promise) {
  const { data, error } = await promise;
  if (error) return res.status(500).json({ error: error.message });
  res.json(data || { success: true });
}

// ============ USUARIOS ============
router.get('/usuarios', async (req, res) => {
  await handleSupabase(res, supabase.from('perfiles').select(', perfiles_usuario()').order('created_at', { ascending: false }));
});

router.patch('/usuarios/:id/rol', async (req, res) => {
  await handleSupabase(res, supabase.from('perfiles').update({ rol: req.body.rol }).eq('id', req.params.id).select());
});

router.patch('/usuarios/:id/activo', async (req, res) => {
  await handleSupabase(res, supabase.from('perfiles').update({ activo: req.body.activo }).eq('id', req.params.id).select());
});

router.delete('/usuarios/:id', async (req, res) => {
  await supabase.rpc('delete_user', { user_id: req.params.id });
  await handleSupabase(res, supabase.from('perfiles').delete().eq('id', req.params.id));
});

// ============ INSTITUCIONES ============
router.get('/instituciones', async (req, res) => {
  await handleSupabase(res, supabase.from('instituciones').select('*').order('nombre'));
});

router.post('/instituciones', async (req, res) => {
  await handleSupabase(res, supabase.from('instituciones').insert(req.body).select().single());
});

router.patch('/instituciones/:id', async (req, res) => {
  await handleSupabase(res, supabase.from('instituciones').update(req.body).eq('id', req.params.id).select().single());
});

router.delete('/instituciones/:id', async (req, res) => {
  await handleSupabase(res, supabase.from('instituciones').delete().eq('id', req.params.id));
});

