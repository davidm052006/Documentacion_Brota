// ============ PREGUNTAS ============
router.get('/preguntas', async (req, res) => {
  const { cuestionario_id } = req.query;
  let query = supabase.from('preguntas').select(', opciones()').order('orden');
  if (cuestionario_id) query = query.eq('cuestionario_id', cuestionario_id);
  await handleSupabase(res, query);
});

router.post('/preguntas', async (req, res) => {
  await handleSupabase(res, supabase.from('preguntas').insert(req.body).select().single());
});

router.patch('/preguntas/:id', async (req, res) => {
  await handleSupabase(res, supabase.from('preguntas').update(req.body).eq('id', req.params.id).select().single());
});

router.delete('/preguntas/:id', async (req, res) => {
