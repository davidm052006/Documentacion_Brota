# Variables de entorno
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Build
backend/dist/
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Obsidian: nunca subir esta carpeta ni nada dentro de ella
.obsidian/

# Papelera local de Obsidian (si la usas)
.trash también la ignoramos)
.trash/

# Archivos temporales del sistema
.DS_Store
Thumbs.db
desktop.ini

# (Opcional) Si usas Excalidraw o Canvas, también puedes ignorar sus cachés
.obsidian/plugins/obsidian-excalidraw/
.obsidian/canvas/

# Kiro: ignorar configuraciones y archivos internos
.kiro/
# Excepción: permitir requirements.md de specs
!.kiro/specs/*/requirements.md

# Archivos personales de aprendizaje (solo local)
docs/ruta_aprendizaje_lider.md
docs/aprendizajes.md
docs/notas_personales.md
